{
    "name": "TaskNodeFlow-Dev-Env",
    "image": "tasknodeflow-env", // 这里对应你之前 build 的镜像名
    
    // 允许容器访问宿主机的图形界面 (X11 转发)
    "runArgs": [
        "--net=host",
        "-e", "DISPLAY=${localEnv:DISPLAY}",
        "-v", "/tmp/.X11-unix:/tmp/.X11-unix"
    ],

    // 容器启动后自动安装的 VS Code 插件
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "twxs.cmake",
                "njpwerner.autodocstring"
            ]
        }
    },

    // 容器内的工作目录
    "workspaceFolder": "/home/TaskNodeFlow",
    "workspaceMount": "source=${localWorkspaceFolder},target=/home/TaskNodeFlow,type=bind",

    // 以 root 运行
    "remoteUser": "root"
}
