{
  "children": [
    {
      "id": "Camera_Source",
      "type": "Sensor",
      "outputs": [
        "raw_frame"
      ]
    },
    {
      "id": "Grayscale_Filter",
      "type": "Atom",
      "inputs": [
        "raw_frame"
      ],
      "outputs": [
        "gray_frame"
      ]
    },
    {
      "id": "Object_Detection",
      "type": "Atom",
      "inputs": [
        "raw_frame"
      ],
      "outputs": [
        "box_coords"
      ]
    },
    {
      "id": "Data_Logger",
      "type": "Atom",
      "inputs": [
        "gray_frame",
        "box_coords"
      ],
      "outputs": [
        "log_status"
      ]
    }
  ]
}
